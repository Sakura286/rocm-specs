From: Sakura286 <sakura286@outlook.com>
Date: Wed, 23 Jul 2025 14:32:32 +0800
Subject: Replace sfence and mfence

---
 clr/hipamd/src/hip_graph_internal.cpp | 8 ++++++++
 clr/rocclr/device/rocm/rocvirtual.cpp | 6 +++++-
 2 files changed, 13 insertions(+), 1 deletion(-)

diff --git a/hipamd/src/hip_graph_internal.cpp b/hipamd/src/hip_graph_internal.cpp
index 20f60a4..a347abc 100644
--- a/hipamd/src/hip_graph_internal.cpp
+++ b/hipamd/src/hip_graph_internal.cpp
@@ -1074,9 +1074,17 @@ void GraphKernelArgManager::ReadBackOrFlush() {
       
       // Read-modify-write sequence with memory barriers
       volatile unsigned char kSentinel = *sentinel_ptr;
+#if !defined(__riscv)
       _mm_sfence();
+#else
+      asm volatile("fence w,w" ::: "memory");
+#endif
       *sentinel_ptr = kSentinel;
+#if !defined(__riscv)
       _mm_mfence();
+#else
+      asm volatile("fence rw,rw" ::: "memory");
+#endif
       kSentinel = *sentinel_ptr;
       (void)kSentinel; // Suppress unused variable warning
     }
diff --git a/rocclr/device/rocm/rocvirtual.cpp b/rocclr/device/rocm/rocvirtual.cpp
index 8b363c2..1ba119e 100644
--- a/rocclr/device/rocm/rocvirtual.cpp
+++ b/rocclr/device/rocm/rocvirtual.cpp
@@ -3722,7 +3722,11 @@ bool VirtualGPU::submitKernelInternal(const amd::NDRangeContainer& sizes,
           asm volatile("fence w,w" ::: "memory");
 #endif
         *(argBuffer + argSize - 1) = *(parameters + argSize - 1);
+#if !defined(__riscv)
         _mm_mfence();
+#else
+        asm volatile("fence rw,rw" ::: "memory");
+#endif
         auto kSentinel = *reinterpret_cast<volatile unsigned char*>(argBuffer + argSize - 1);
       }
     }
