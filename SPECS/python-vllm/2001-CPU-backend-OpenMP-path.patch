# CPU backend: OPEN_MP is only a presence assert (never linked; -fopenmp does the linking). find_library(gomp) is unsatisfiable on RPM distros (no /usr/lib64/libgomp.so), so use CMake's canonical find_package(OpenMP).
#
--- a/cmake/cpu_extension.cmake	2026-06-04 08:11:47.000000000 +0800
+++ b/cmake/cpu_extension.cmake	2026-06-17 11:13:40.079348791 +0800
@@ -48,7 +48,7 @@
         set(ENV{LD_LIBRARY_PATH} "${VLLM_TORCH_GOMP_SHIM_DIR}:$ENV{LD_LIBRARY_PATH}")
     else()
         # Fall back to system / toolchain libgomp
-        find_library(OPEN_MP NAMES gomp REQUIRED)
+        find_package(OpenMP REQUIRED)
     endif()
 endif()
 
