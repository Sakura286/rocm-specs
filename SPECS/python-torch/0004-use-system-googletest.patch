From 90d7693267ed1e5c6e852609b156f79adf6ddac2 Mon Sep 17 00:00:00 2001
From: CHEN Xuan <chenxuan@iscas.ac.cn>
Date: Wed, 1 Jul 2026 15:11:12 +0800
Subject: [PATCH] use system googletest

Replace the vendored third_party/googletest add_subdirectory() with
find_package(GTest) so the distro's gtest-devel / gmock-devel (shared
libs) are used instead of a statically-linked vendored copy.  This
follows the distro-packaging convention of not vendoring libraries the
distribution already ships.

PyTorch's test CMakeLists link the bare target names
  gtest, gtest_main, gmock, gmock_main
but find_package(GTest) provides the GTest::-prefixed imported targets,
so ALIAS targets map the bare names to the imported ones.

The BUILD_SHARED_LIBS=OFF save/set/restore around the block is kept so
the vendored benchmark (still built via add_subdirectory below) stays
static; only the gtest-specific lines are removed.
---
 cmake/Dependencies.cmake | 19 ++++++++++---------
 1 file changed, 10 insertions(+), 9 deletions(-)

diff --git a/cmake/Dependencies.cmake b/cmake/Dependencies.cmake
index dac0d1f..9a20c6f 100644
--- a/cmake/Dependencies.cmake
+++ b/cmake/Dependencies.cmake
@@ -650,17 +650,18 @@ if(BUILD_TEST OR BUILD_MOBILE_BENCHMARK OR BUILD_MOBILE_TEST)
   # Preserve build options.
   set(TEMP_BUILD_SHARED_LIBS ${BUILD_SHARED_LIBS})
 
-  # We will build gtest as static libs and embed it directly into the binary.
+  # Build the vendored benchmark (below) as a static lib.
   set(BUILD_SHARED_LIBS OFF CACHE BOOL "Build shared libs" FORCE)
 
-  # For gtest, we will simply embed it into our test binaries, so we won't
-  # need to install it.
-  set(INSTALL_GTEST OFF CACHE BOOL "Install gtest." FORCE)
-  set(BUILD_GMOCK ON CACHE BOOL "Build gmock." FORCE)
-
-  add_subdirectory(${CMAKE_CURRENT_LIST_DIR}/../third_party/googletest)
-  include_directories(BEFORE SYSTEM ${CMAKE_CURRENT_LIST_DIR}/../third_party/googletest/googletest/include)
-  include_directories(BEFORE SYSTEM ${CMAKE_CURRENT_LIST_DIR}/../third_party/googletest/googlemock/include)
+  # Use the system googletest (openRuyi gtest-devel) instead of the vendored
+  # submodule.  PyTorch's test CMakeLists link the bare target names
+  # gtest / gtest_main / gmock / gmock_main, but find_package(GTest) provides
+  # the GTest::-prefixed imported targets, so alias the bare names to them.
+  find_package(GTest REQUIRED CONFIG)
+  add_library(gtest ALIAS GTest::gtest)
+  add_library(gtest_main ALIAS GTest::gtest_main)
+  add_library(gmock ALIAS GTest::gmock)
+  add_library(gmock_main ALIAS GTest::gmock_main)
 
   # We will not need to test benchmark lib itself.
   set(BENCHMARK_ENABLE_TESTING OFF CACHE BOOL "Disable benchmark testing as we don't need it.")
-- 
