From: Sakura286 <sakura286@outlook.com>
Date: Mon, 29 Jun 2026 19:10:00 +0800
Subject: Replace fence and cache flush instructions for riscv64

Replace _mm_sfence/_mm_mfence with RISC-V fence equivalents, and
replace _mm_clflush with cbo.flush (Zicbom extension).

--- a/runtime/hsa-runtime/core/inc/amd_gpu_agent.h
+++ b/runtime/hsa-runtime/core/inc/amd_gpu_agent.h
@@ -439,9 +439,17 @@
   /// @brief Force a WC flush on PCIe devices by doing a write and then read-back
   __forceinline void PcieWcFlush(void *ptr, size_t size) const {
     if (!xgmi_cpu_gpu_) {
-      _mm_sfence();
+  #if !defined(__riscv)
+    _mm_sfence();
+#else
+    asm volatile("fence w,w" ::: "memory");
+#endif
       *((uint8_t*)ptr + size - 1) = *((uint8_t*)ptr + size - 1);
-      _mm_mfence();
+  #if !defined(__riscv)
+    _mm_mfence();
+#else
+    asm volatile("fence rw,rw" ::: "memory");
+#endif
       auto readback = *(reinterpret_cast<volatile uint8_t*>(ptr) + size - 1);
       UNUSED(readback);
     }

